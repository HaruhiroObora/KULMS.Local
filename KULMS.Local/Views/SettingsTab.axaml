<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KULMS.Local.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KULMS.Local.Views.SettingsTab"
             x:DataType="vm:SettingsTabViewModel">

  <Grid RowDefinitions="*,Auto">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" Grid.Row="0">
      <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="授業資料の保存先" FontSize="20"/>
        <TextBox Text="{Binding LocalDirectoryPrefix}" FontSize="15"/>
        <TextBlock Text="Chromeの実行ファイルパス" FontSize="20"/>
        <TextBox Text="{Binding BrowserExecutablePath}" FontSize="15"/>
        <TextBlock Text="LMSのドメイン" FontSize="20"/>
        <TextBox Text="{Binding Domain}" FontSize="15"/>
        <TextBlock Text="ID" FontSize="20"/>
        <TextBox Text="{Binding ID}" FontSize="15"/>
        <ToggleSwitch Content="サイト一覧の更新を有効にする(次回の起動から反映されます)" IsChecked="{Binding SiteRefresh}" FontSize="20"/>
      </StackPanel>
    </ScrollViewer>
    <Button Content="保存" Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Right"/>
  </Grid>


</UserControl>
